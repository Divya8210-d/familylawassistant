    ]
  },
  {
    "id": "e7914a84-12eb-4da0-9ca4-eaad94dcf96d",
    "source": "https://en.wikipedia.org/wiki/Prenuptial_agreement",
    "title": "Prenuptial Agreements and Their Limited Recognition in Indian Family Law",
    "summary": "A prenuptial (or antenuptial) agreement is a written contract entered into before marriage that allows parties to determine the distribution of property, spousal support, and other marital rights upon divorce or death. In India, no specific statute governs such agreements; they are assessed under the Indian Contract Act, 1872 and must not contravene the Hindu Marriage Act or public policy. Courts have so far declined to enforce prenuptial agreements, though a memorandum of settlement may be used during divorce proceedings. Goa is an exception, where the Portuguese Civil Code of 1867 permits enforceable antenuptial contracts that determine matrimonial property regimes.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Indian Contract Act, 1872"
      },
      {
        "type": "act",
        "name": "Hindu Marriage Act, 1955"
      },
      {
        "type": "act",
        "name": "Portuguese Civil Code of 1867"
      },
      {
        "type": "state",
        "name": "Goa"
      },
      {
        "type": "concept",
        "name": "Prenuptial agreement"
      },
      {
        "type": "concept",
        "name": "Antenuptial contract"
      },
      {
        "type": "concept",
        "name": "Community of property"
      },
      {
        "type": "concept",
        "name": "Accrual system"
      },
      {
        "type": "court",
        "name": "District Courts of India"
      },
      {
        "type": "case",
        "name": "Memorandum of Settlement (divorce context)"
      }
    ],
    "sections": [
      {
        "title": "Definition and Scope",
        "content": "Prenuptial agreements are written contracts signed by prospective spouses to set out the division of assets, spousal support, and other rights that would otherwise be governed by default matrimonial law."
      },
      {
        "title": "Global Legal Recognition",
        "content": "Jurisdictions differ widely: some nations treat prenups as enforceable contracts, while others limit them to property protection during marriage or require registration. This variability informs the Indian context, where no dedicated legislation exists."
      },
      {
        "title": "Indian Legal Context",
        "content": "In India, prenups are rare and lack statutory backing. Their enforceability is judged under the Indian Contract Act, which requires free consent, lawful consideration, and compliance with public policy. The Hindu Marriage Act's provisions on matrimonial property remain applicable, and courts have not yet ruled on the direct enforcement of prenups."
      },
      {
        "title": "Enforceability Criteria",
        "content": "For a prenup to be considered a valid contract in India, it must (a) be entered into with free consent, (b) not be immoral or contrary to public policy per Section 23 of the Contract Act, and (c) not violate mandatory provisions of personal law statutes such as the Hindu Marriage Act."
      },
      {
        "title": "Exceptional Jurisdiction – Goa",
        "content": "Goa follows the Portuguese Civil Code, which permits antenuptial contracts that determine the matrimonial property regime at the time of marriage. In the absence of such a contract, Goa’s default rule is equal division of marital property."
      },
      {
        "title": "Related Legal Instruments",
        "content": "While prenups are seldom enforced, Indian courts may accept a memorandum of settlement during divorce proceedings to resolve financial disputes, functioning as a limited post‑nuptial arrangement."
      }
    ],
    "keywords": [
