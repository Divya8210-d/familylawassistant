  {
    "id": "156fe6de-1917-4447-ae96-7bcdcc95aca6",
    "source": "https://www.livelaw.in/top-stories/marriage-equality-case-justice-sanjiv-khanna-recuses-from-hearing-review-petitions-in-supreme-court-262920",
    "title": "Justice Sanjiv Khanna Recuses from Supreme Court Review Petitions on Marriage Equality",
    "summary": "The Supreme Court of India has listed review petitions challenging the landmark judgment that decriminalised consensual same‑sex relations and affirmed marriage equality. Justice Sanjiv Khanna, who was part of the bench that delivered the original judgment, withdrew from hearing the review petitions, citing the need to avoid any perception of bias. The remaining judges will continue the deliberations, with the petitions seeking to overturn the pronouncement that the Constitution guarantees the right to marry regardless of sexual orientation. The case underscores the evolving jurisprudence on equality, non‑discrimination, and fundamental rights under the Constitution. The recusal also raises procedural questions about bench composition and the handling of high‑profile constitutional review applications.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "court",
        "name": "Supreme Court of India"
      },
      {
        "type": "judge",
        "name": "Justice Sanjiv Khanna"
      },
      {
        "type": "judge",
        "name": "Justice D.Y. Chandrachud"
      },
      {
        "type": "judge",
        "name": "Justice Chandramouli Kr. Prasad"
      },
      {
        "type": "case",
        "name": "Navtej Singh Johar v. Union of India (2018)"
      },
      {
        "type": "act",
        "name": "Indian Penal Code, Section 377"
      },
      {
        "type": "concept",
        "name": "Marriage Equality"
      },
      {
        "type": "concept",
