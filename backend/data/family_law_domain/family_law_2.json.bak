        "name": "Void marriage"
      },
      {
        "type": "Concept",
        "name": "Injunction"
      },
      {
        "type": "Concept",
        "name": "Abetment"
      },
      {
        "type": "Concept",
        "name": "Legitimacy"
      },
      {
        "type": "Concept",
        "name": "Majority"
      }
    ],
    "sections": [
      {
        "title": "Section 2 – Definition of child",
        "content": "A child is defined as a male who has not attained the age of 21 years and a female who has not attained the age of 18 years."
      },
      {
        "title": "Section 3 – Voidable child marriages",
        "content": "A marriage involving a child is voidable; the child may apply for annulment within two years after reaching the age of majority."
      },
      {
        "title": "Section 5 – Injunctions",
        "content": "The court may issue an injunction to restrain any person from solemnising or participating in a child marriage."
      },
      {
        "title": "Section 9 – Penalty for adult male marrying a child",
        "content": "Any adult male who marries a child is punishable with imprisonment for up to two years or a fine, or both."
      },
      {
        "title": "Section 10 – Penalty for officiant",
        "content": "A person who conducts or performs a child marriage faces the same penalty as provided in Section 9."
      },
      {
        "title": "Section 11 – Penalty for promoters/abettors",
        "content": "Anyone who promotes, abets, or facilitates a child marriage is liable to the same punishment as the adult male marrying the child."
      },
      {
        "title": "Section 13 – Child Marriage Prohibition Officer",
        "content": "The State shall appoint a Child Marriage Prohibition Officer to enforce the provisions of the Act."
      },
      {
        "title": "Section 15 – Void child marriages",
        "content": "A child marriage is void if it is contracted against the child's will or by force, threat, or intimidation."
      },
      {
        "title": "Section 16 – Legitimacy of children",
        "content": "Children born from a marriage that is void or voidable under the Act are considered legitimate."
      }
    ],
