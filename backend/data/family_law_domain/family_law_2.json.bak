    ]
  },
  {
    "id": "bbfd6898-696c-4561-bc2a-712c751d9601",
    "source": "https://en.wikipedia.org/wiki/Hindu_Minority_and_Guardianship_Act,_1956",
    "title": "Hindu Minority and Guardianship Act, 1956",
    "summary": "The Hindu Minority and Guardianship Act, 1956 supplements the Guardians and Wards Act, 1890, and governs guardianship relationships for Hindu minors and their property. It defines a minor as a person under 18 and outlines the hierarchy of natural guardians—father as primary for legitimate children, mother for illegitimate children, and special provisions for children under five and adoptive families. The Act emphasizes the welfare and best interests of the minor, restricting guardians from alienating immovable property and stating that any inconsistent prior law is void. It applies to all Hindus and related religions, excluding Muslims, Christians, Parsis, and Jews unless proven otherwise. Feminist critiques highlight gender bias, prompting courts to evolve the principle of the child's best interests.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Hindu Minority and Guardianship Act, 1956"
      },
      {
        "type": "act",
        "name": "Guardians and Wards Act, 1890"
      },
      {
        "type": "act",
        "name": "Hindu Marriage Act, 1955"
      },
      {
        "type": "act",
        "name": "Hindu Succession Act, 1956"
      },
      {
        "type": "act",
        "name": "Hindu Adoptions and Maintenance Act, 1956"
      },
      {
        "type": "person",
        "name": "Jawaharlal Nehru"
      },
      {
        "type": "court",
        "name": "Court of Wards"
      },
      {
        "type": "concept",
        "name": "Natural guardian"
      },
      {
        "type": "concept",
        "name": "Best interests of the child"
      },
      {
        "type": "concept",
        "name": "Legitimate child"
      },
      {
        "type": "concept",
        "name": "Illegitimate child"
      }
    ],
    "sections": [
      {
        "title": "Introduction",
        "content": "Positions the Act as one of the four Hindu Code Bills enacted in 1956 to modernise Hindu personal law and clarifies its role as a supplementary statute to the Guardians and Wards Act, 1890."
      },
      {
        "title": "Important definitions",
        "content": "Defines a minor as any person below 18 years and outlines categories of guardians: natural guardians, parents‑chosen guardians, court‑appointed guardians, and Court of Wards guardians."
      },
      {
        "title": "Overriding quality",
        "content": "Declares that any prior law inconsistent with the Act is void, giving the Act supremacy over earlier statutes concerning Hindu guardianship."
      },
      {
        "title": "Application",
        "content": "Specifies that the Act applies to all Hindus and related faiths (e.g., Lingayat, Brahmo, Sikh, Jain) while excluding Muslims, Christians, Parsis and Jews unless they were previously governed by Hindu law."
      },
      {
        "title": "Natural guardians",
        "content": "Sets out the hierarchy: father is primary guardian for legitimate boys and unmarried girls, mother is secondary; mother is primary for illegitimate children; mother is ordinary guardian for children under five; a married minor girl's husband becomes her guardian; adoptive parents follow similar rules."
      },
      {
        "title": "Abilities of natural guardians",
        "content": "Allows guardians to protect the minor and property but prohibits personal covenants, sale, mortgage, or long‑term lease of immovable property, with specific time limits after the child turns eighteen."
      },
      {
        "title": "Minors and property",
        "content": "States a child cannot be appointed as guardian of another minor’s property and that no guardian is appointed for a minor’s undivided interest in joint family property already controlled by an adult."
      },
      {
        "title": "Welfare of the minor",
        "content": "Mandates that the best interests and welfare of the minor are the paramount considerations in any guardianship appointment."
      },
      {
        "title": "Lacunae",
        "content": "Highlights feminist criticism of gender bias favoring fathers, the evolution of judicial interpretation toward the child’s best interests, and case law expanding mothers’ rights to sole guardianship."
      }
    ],
    "keywords": [
