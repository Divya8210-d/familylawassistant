  {
    "id": "db07d396-5ba5-4c14-9b64-6425c7fcb6b3",
    "source": "https://www.barandbench.com/news/litigation/marriage-victim-rapepocso-kerala-high-court",
    "title": "Kerala HC Declares Marriage Does Not Bar POCSO Rape Prosecution of Minor",
    "summary": "The Kerala High Court held that the fact a girl is married does not immunise the accused from prosecution under the Protection of Children from Sexual Offences (POCSO) Act for rape. The court clarified that a minor, irrespective of marital status, cannot consent to sexual intercourse and any act of sexual penetration constitutes rape under Section 376 of the IPC and the relevant provisions of POCSO. The judgment reiterated that the marriage of a minor is void under the Prohibition of Child Marriage Act, 2006, and ordered protection measures, compensation and speedy trial. This ruling affirms that marital status is irrelevant when assessing offences against children and strengthens the legal safeguards for child victims of sexual violence.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "court",
        "name": "Kerala High Court"
      },
      {
        "type": "statute",
        "name": "Protection of Children from Sexual Offences (POCSO) Act, 2012"
      },
      {
        "type": "statute",
        "name": "Indian Penal Code, Section 376"
      },
      {
        "type": "statute",
        "name": "Prohibition of Child Marriage Act, 2006"
      },
      {
        "type": "concept",
        "name": "Minor"
      },
      {
        "type": "concept",
        "name": "Marital Rape"
      },
      {
        "type": "concept",
        "name": "Consent"
      },
      {
        "type": "person",
        "name": "Victim (minor girl)"
      },
      {
        "type": "person",
        "name": "Accused"
      }
    ],
    "sections": [
      {
        "title": "Background",
        "content": "A minor girl, already married under a child marriage, was allegedly raped by the accused. The trial court had dismissed the POCSO complaint on the ground that the victim was married."
      },
      {
        "title": "Legal Issue",
        "content": "Whether the marital status of a minor bars prosecution under the POCSO Act for rape and whether a child marriage renders the marriage void for the purpose of criminal law."
      },
      {
        "title": "Judgment",
        "content": "The Kerala High Court ruled that marriage of a minor is prohibited and void, and the minor cannot give lawful consent. Consequently, the accused is liable under POCSO and IPC for rape, irrespective of the victim's marital status."
      },
      {
        "title": "Directions and Relief",
        "content": "The court ordered protective custody for the victim, immediate compensation under the Victims of Crime Act, and directed the trial court to expedite the criminal proceedings."
      },
      {
        "title": "Implications",
        "content": "The decision strengthens the legal position that child marriage does not provide a shield against sexual offences and reinforces the primacy of child protection statutes over matrimonial considerations."
      }
    ],
    "keywords": [
      "Kerala High Court",
      "POCSO Act",
      "marital rape",
      "child marriage",
      "minor consent",
      "rape prosecution",
      "void marriage",
      "criminal law",
      "protection of children",
      "IPC Section 376",
      "legal remedy",
      "compensation",
      "protective custody",
      "jurisprudence"
    ]
  },
