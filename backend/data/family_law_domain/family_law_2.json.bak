      },
      {
        "type": "act",
        "name": "Hindu Succession Act"
      },
      {
        "type": "court",
        "name": "Supreme Court of India"
      },
      {
        "type": "court",
        "name": "Kerala High Court"
      },
      {
        "type": "court",
        "name": "Delhi High Court"
      },
      {
        "type": "case",
        "name": "Supriyo v. Union of India (2023)"
      },
      {
        "type": "person",
        "name": "Henry Sumner Maine"
      },
      {
        "type": "concept",
        "name": "Articles 14, 15, 19 and 21 of the Indian Constitution"
      },
      {
        "type": "concept",
        "name": "Civil contract"
      },
      {
        "type": "concept",
        "name": "Marriage Registrar"
      }
    ],
    "sections": [
      {
        "title": "Background",
        "content": "The Act evolved from the 19th‑century legislation (Act III, 1872) introduced by Henry Sumner Maine to permit dissenters to marry without religious restriction. The 1954 enactment superseded that law, aiming to create a special form of marriage, ensure registration, and provide for divorce."
      },
      {
        "title": "Applicability",
        "content": "The Act applies to any person in India or Indian nationals abroad, regardless of religion—Hindu, Muslim, Sikh, Christian, Jain, Buddhist, Parsi, Jewish—or to atheists and agnostics, and also to inter‑religious couples and foreign nationals marrying an Indian citizen."
      },
      {
        "title": "Procedure",
        "content": "Couples file a Notice of Intended Marriage with the district Marriage Registrar after a minimum 30‑day residence, publicise the notice, observe a 30‑day objection period, and then solemnise the marriage before a Marriage Officer and three witnesses, after which a marriage certificate is issued."
      },
      {
        "title": "Conditions for Marriage",
        "content": "Both parties must be unmarried, the groom at least 21 years old and the bride at least 18, possess mental capacity to consent, and not fall within prohibited degrees of relationship."
      },
      {
        "title": "Succession to the Property",
        "content": "Property succession for persons married under the Act follows the Indian Succession Act, except where the parties are Hindu, Buddhist, Sikh or Jain, in which case the Hindu Succession Act applies."
      },
      {
        "title": "Judicial Review",
        "content": "The Supreme Court, in Supriyo v. Union of India (2023), was petitioned to strike down the notice and objection provisions as violative of constitutional rights under Articles 14, 15, 19 and 21, extending the challenge to similar provisions in the Foreign Marriage Act, 1969."
      }
    ],
