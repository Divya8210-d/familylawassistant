  {
    "id": "3243f87f-d423-4b70-bf98-0c2e6fdb18ff",
    "source": "https://en.wikisource.org/wiki/Muslim_Personal_Law_(Shariat)_Application_Act,_1937",
    "title": "Muslim Personal Law (Shariat) Application Act, 1937 – Scope and Key Provisions",
    "summary": "The Muslim Personal Law (Shariat) Application Act, 1937 mandates that the Shariat governs all personal law matters for Muslims, superseding any contrary custom or usage. Section 2 specifically enumerates the subjects to which the Shariat applies, including intestate succession, dower (mehr), marriage, dissolution of marriage, maintenance, guardianship, gifts, trusts and wakfs. The Act operates alongside later statutes such as the Dissolution of Muslim Marriages Act, 1939 and the Muslim Women (Protection of Rights on Marriage) Act, 2019, which address grounds for divorce and criminalise instant triple talaq respectively. By codifying the application of Islamic law in these domains, the Act provides a statutory basis for the personal law of Muslims in India.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Muslim Personal Law (Shariat) Application Act, 1937"
      },
      {
        "type": "act",
        "name": "Dissolution of Muslim Marriages Act, 1939"
      },
      {
        "type": "act",
        "name": "Muslim Women (Protection of Rights on Marriage) Act, 2019"
      },
      {
        "type": "concept",
        "name": "Shariat (Muslim Personal Law)"
      },
      {
        "type": "concept",
        "name": "Intestate succession"
      },
      {
        "type": "concept",
        "name": "Mehr (Dower)"
      },
      {
        "type": "concept",
        "name": "Triple talaq (talaq‑e‑biddat)"
      },
      {
        "type": "concept",
        "name": "Wakf"
      }
    ],
    "sections": [
      {
        "title": "Application of Shariat (Section 2)",
        "content": "Notwithstanding any custom or usage, the Shariat shall apply to Muslims in all questions relating to intestate succession, special property of females, marriage, dissolution of marriage, maintenance, dower, guardianship, gifts, trusts and trust properties, and wakfs."
      },
      {
        "title": "Scope of Matters Covered",
        "content": "The Act expressly brings under Shariat law the core personal law domains, ensuring uniformity across Muslim communities and overriding conflicting local customs."
      },
      {
        "title": "Relation to Dissolution of Muslim Marriages Act, 1939",
        "content": "While the 1937 Act sets the overarching applicability of Shariat, the 1939 Act enumerates specific grounds on which a Muslim wife may seek dissolution of marriage, such as the husband's disappearance, failure to maintain, imprisonment, impotence, insanity, disease, early marriage, and cruelty."
      },
      {
        "title": "Mehr (Dower) Provisions",
        "content": "Mehr, an amount payable by the husband to the wife, may be prompt (mu’ajjal) or deferred (mu’wajjal). A wife may lawfully refuse cohabitation until the prompt portion of the mehr has been paid."
      },
      {
        "title": "Interaction with Triple Talaq Legislation",
        "content": "The Muslim Women (Protection of Rights on Marriage) Act, 2019 criminalises instant triple talaq (talaq‑e‑biddat) as a cognisable, non‑bailable offence, complementing the 1937 Act's emphasis on Shariat‑based marital governance."
      }
    ],
    "keywords": [
      "Shariat",
