      },
      {
        "type": "judge",
        "name": "Dharnidhar Jha"
      },
      {
        "type": "magistrate",
        "name": "P.C. Pandey"
      },
      {
        "type": "case",
        "name": "Nagarnausa P.S. case no.12 of 2008"
      },
      {
        "type": "legal_proceeding",
        "name": "Cr.Misc. No.21549 of 2008"
      }
    ],
    "sections": [
      {
        "title": "Background",
        "content": "Petitioner was discovered in possession of a country‑made pistol and associated ammunition during a police lookout for an accused in an unrelated case."
      },
      {
        "title": "Court Findings",
        "content": "The High Court found the presence of the weapon sufficient grounds to deny bail and consequently dismissed the petition for release."
      },
      {
        "title": "Order",
        "content": "The petitioner shall remain in custody for a period of one year from the first day of his remand in Nagarnausa P.S. case no.12 of 2008. After this period, he may be released upon furnishing a bond satisfactory to Judicial Magistrate P.C. Pandey, Ist Class, Hilsa, Nalanda."
      }
