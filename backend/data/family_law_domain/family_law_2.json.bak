      },
      {
        "type": "act",
        "name": "Hindu Minority and Guardianship Act, 1956"
      },
      {
        "type": "act",
        "name": "Hindu Adoptions and Maintenance Act, 1956"
      },
      {
        "type": "act",
        "name": "Special Marriage Act, 1954"
      },
      {
        "type": "act",
        "name": "Indian Penal Code (Section 498A)"
      },
      {
        "type": "act",
        "name": "Anand Marriage (Amendment) Bill, 2012"
      },
      {
        "type": "constitution",
        "name": "Article 44 of the Indian Constitution"
      },
      {
        "type": "person",
        "name": "Duncan Derrett"
      },
      {
        "type": "institution",
        "name": "Registrar of Marriage"
      }
    ],
    "sections": [
      {
        "title": "Purpose",
        "content": "The Act was enacted to amend and codify Hindu marriage law, bringing uniformity across Hindu sects and incorporating provisions for separation and divorce that were previously absent from traditional Shastrik law."
      },
      {
        "title": "Applicability",
        "content": "Section 2 extends the Act to Hindus (including Virashaiva, Lingayat, Brahmo Samaj, Prarthana Samaj, Arya Samaj), Buddhists, Jains, Sikhs and any other non‑Muslim, non‑Christian, non‑Parsi, non‑Jew domiciled in India; it also applies to Hindus abroad if domiciled in India."
      },
      {
        "title": "Conditions for a Valid Marriage (Section 5)",
        "content": "A marriage is valid only if both parties are unmarried, of sound mind, the groom is at least 21 years old, the parties are not within prohibited degrees of relationship, and they are not sapindas unless custom permits."
      },
      {
        "title": "Guardianship (Section 6)",
        "content": "Specifies the hierarchy of persons (father, mother, paternal grandparents, full‑blood brothers, etc.) whose consent is required for the marriage of a bride."
      },
      {
        "title": "Registration of Marriage (Section 8)",
        "content": "Mandates that marriages be registered by the Registrar of Marriage on the same working day of application, after verification of documents, and a marriage certificate is issued."
      },
      {
        "title": "Amendments and Related Legislation",
        "content": "The 2012 Anand Marriage Amendment provided a separate personal law for Sikhs; Section 498A of the IPC (added in 1983) protects married women from cruelty; the Special Marriage Act, 1954 offers a secular alternative for inter‑religious unions."
      },
      {
        "title": "Cultural Context",
        "content": "Traditionally, Hindu marriage was a private, sacral union without state involvement; the Act introduced civil regulation, sparking religious opposition, especially to the concept of divorce and equal inheritance rights for daughters."
      }
    ],
