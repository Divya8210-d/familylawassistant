    ]
  },
  {
    "id": "2478c225-d345-49e8-87f9-220323adffe3",
    "source": "https://en.wikipedia.org/wiki/Alimony",
    "title": "Alimony – Legal Obligation of Spousal Support",
    "summary": "Alimony, also known as maintenance or spousal support, is a legal duty to provide financial assistance to a spouse during separation or after divorce. The obligation varies across jurisdictions and may be influenced by fault, no‑fault divorce statutes, prenuptial agreements, and gender‑bias jurisprudence. Historically derived from ancient codes and English ecclesiastical courts, modern alimony regimes distinguish between permanent, rehabilitative, and temporary awards. Contemporary reforms aim to align alimony with self‑sufficiency while addressing gender equity and domestic‑violence concerns.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "legal_code",
        "name": "Code of Hammurabi"
      },
      {
        "type": "legal_code",
        "name": "Code of Justinian"
      },
      {
        "type": "court",
        "name": "English ecclesiastical courts"
      },
      {
        "type": "organization",
        "name": "American Bar Association"
      },
      {
        "type": "court",
        "name": "U.S. Supreme Court"
      },
      {
        "type": "concept",
        "name": "Fault‑based alimony"
      },
      {
        "type": "concept",
        "name": "No‑fault alimony"
      },
      {
        "type": "concept",
        "name": "Permanent alimony"
      },
      {
        "type": "concept",
        "name": "Rehabilitative alimony"
      },
      {
        "type": "concept",
        "name": "Gender bias in alimony"
      },
      {
        "type": "person",
        "name": "Britney Spears"
      },
      {
        "type": "person",
        "name": "Victoria Principal"
      },
      {
        "type": "person",
        "name": "Jessica Simpson"
      }
    ],
    "sections": [
      {
        "title": "Etymology",
        "content": "The term 'alimony' derives from the Latin alimonia, meaning nourishment or sustenance, and is related to the Scots law concept of 'aliment' providing for a wife's basic needs after divorce."
      },
      {
        "title": "Historical Development",
        "content": "Ancient legal codes such as the Code of Hammurabi mandated support for women with children. Medieval English ecclesiastical courts introduced alimony pendente lite and permanent alimony based on the view that marriage persisted despite separation."
      },
      {
        "title": "Fault‑Based Alimony",
        "content": "Under fault‑based regimes, alimony was linked to marital misconduct; husbands typically paid support because the marriage would have continued absent their fault, whereas wives who were at fault forfeited the right to support."
      },
      {
        "title": "No‑Fault Alimony",
        "content": "The advent of no‑fault divorce shifted alimony from a guaranteed right to a discretionary award, with marital fault serving only as a factor in many U.S. states. Critics note that this can disadvantage domestic‑violence survivors."
      },
      {
        "title": "Types of Alimony",
        "content": "Permanent alimony provides lifelong support but is declining in favor of rehabilitative alimony, which aims to help the recipient become financially independent through education or training."
      },
      {
        "title": "Gender Bias and Reform",
        "content": "U.S. Supreme Court decisions in the 1970s addressed gender bias, leading to a modest rise in male alimony recipients. Some jurisdictions now consider the earning potential of new spouses in determining awards."
      },
      {
        "title": "Procedure",
        "content": "Procedural rules differ by country; generally, parties must file a petition for support during divorce proceedings, and courts assess need, ability to pay, duration of the marriage, and other statutory factors."
      }
    ],
    "keywords": [
      "alimony",
      "spousal support",
      "maintenance",
      "fault‑based alimony",
      "no‑fault divorce",
      "permanent alimony",
      "rehabilitative alimony",
      "gender bias",
      "marital separation",
      "divorce law",
      "child support",
      "prenuptial agreement",
      "financial assistance"
    ]
  },
  {
    "id": "2a9b9e09-e9bc-4abf-b303-3f2f1c382def",
    "source": "https://en.wikipedia.org/wiki/Child_custody",
    "title": "Child Custody: Legal and Physical Custody Framework",
    "summary": "Child custody delineates the legal and practical relationship between a parent or guardian and a child. It comprises legal custody, the authority to make major life decisions for the child, and physical custody, the responsibility to house and care for the child. In most jurisdictions, custody determinations are guided by the \"best interests of the child\" standard, and terminology is shifting toward \"residence\" and \"contact\" following the UN Convention on the Rights of the Child. Custody arrangements can be joint or sole, and physical custody may take various forms such as joint, sole, bird's‑nest, split, alternating, or third‑party custody. The prevalence of different custody models varies widely across countries.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "United Nations Convention on the Rights of the Child"
      },
      {
        "type": "concept",
        "name": "legal custody"
      },
      {
        "type": "concept",
        "name": "physical custody"
      },
      {
        "type": "concept",
        "name": "joint custody"
      },
      {
        "type": "concept",
        "name": "sole custody"
      },
      {
        "type": "concept",
        "name": "best interests of the child"
      },
      {
        "type": "concept",
        "name": "parental responsibility"
      },
      {
        "type": "concept",
        "name": "residence"
      },
      {
        "type": "concept",
        "name": "contact (visitation)"
      }
    ],
    "sections": [
      {
        "title": "Legal custody",
        "content": "Legal custody concerns the division of decision‑making rights between parents regarding major aspects of a child's life, such as education, medical treatment, and religion. It may be exercised jointly by both parents or solely by one parent."
      },
      {
        "title": "Physical custody",
        "content": "Physical custody determines where the child lives and who is responsible for day‑to‑day care. A court‑ordered parenting schedule or plan specifies the periods each parent provides lodging and care."
      },
      {
        "title": "Forms of physical custody",
        "content": "Physical custody can take several forms: sole custody (one parent), joint physical custody (shared time), bird's‑nest (child remains in one home), split custody (different children with different parents), alternating custody (extended periods with each parent), and third‑party custody (custody by a non‑parent)."
      },
      {
        "title": "Joint physical custody",
        "content": "In joint physical custody, the child spends roughly equal time with both parents, both are considered custodial parents, and the arrangement is governed by a court‑approved parenting schedule rather than visitation orders."
      },
      {
        "title": "Sole custody",
        "content": "Sole physical custody means the child resides with one parent, who is the custodial parent, while the other parent may have visitation or contact rights as defined by the court."
      },
      {
        "title": "Prevalence",
        "content": "Cross‑national studies show wide variation in the proportion of children living with both parents and the types of custody arrangements, with shared parenting being most common in some European nations and less prevalent in others such as the United States."
      }
    ],
    "keywords": [
      "child custody",
      "legal custody",
      "physical custody",
      "joint custody",
      "sole custody",
      "parental responsibility",
      "best interests of the child",
      "parenting plan",
      "visitation",
      "residence",
      "contact",
      "UN Convention on the Rights of the Child",
      "bird's‑nest custody",
      "split custody",
      "alternating custody"
    ]
  },
  {
    "id": "04dded78-cb50-4f96-bc1a-bdbef0982400",
    "source": "https://en.wikipedia.org/wiki/Surrogacy_in_India",
    "title": "Regulation of Surrogacy in India",
    "summary": "India emerged as a global hub for commercial gestational surrogacy in the early 2000s, attracting foreign intended parents with low costs and minimal oversight. Following a series of high‑profile abuses, the government imposed incremental bans, first restricting foreign homosexual couples and single parents in 2013 and then outlawing commercial surrogacy altogether in 2015. Successive Surrogacy (Regulation) Bills (2016, 2019, 2020) narrowed eligibility to altruistic arrangements for Indian heterosexual married couples with infertility, eventually culminating in the Surrogacy (Regulation) Act 2021. The Act codifies surrogate eligibility, reimbursement limits, and prohibits commercial payment, while extending limited altruistic access to certain widowed or divorced women. The legal framework reflects a shift from a liberal, tourism‑driven model to a restrictive, protection‑oriented regime.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "bill",
        "name": "Surrogacy (Regulation) Bill 2016"
      },
      {
        "type": "bill",
        "name": "Surrogacy (Regulation) Bill 2019"
      },
      {
        "type": "bill",
        "name": "Surrogacy (Regulation) Bill 2020"
      },
      {
        "type": "act",
        "name": "Surrogacy (Regulation) Act 2021"
      },
      {
        "type": "guideline",
        "name": "National Guidelines for the Accreditation, Supervision and Regulation of ART Clinics in India (2002)"
      },
      {
        "type": "guideline",
        "name": "Indian Council of Medical Research (ICMR) Guidelines 2005"
      },
      {
        "type": "organization",
        "name": "Lok Sabha"
      },
      {
        "type": "organization",
        "name": "Rajya Sabha"
      },
      {
        "type": "organization",
        "name": "Confederation of Indian Industry"
      },
      {
        "type": "organization",
        "name": "United Nations"
      },
      {
        "type": "court_decision",
        "name": "2002 Court Decision Legalising Commercial Surrogacy"
      }
    ],
    "sections": [
      {
        "title": "Early Commercial Surge (2000‑2012)",
        "content": "Assisted reproductive technologies expanded rapidly; clinics offered package surrogacy services to Indian and foreign clients, making India a leading destination for low‑cost commercial gestational surrogacy."
      },
      {
        "title": "Initial Regulatory Steps",
        "content": "The 2002 National Guidelines and 2005 ICMR guidelines introduced accreditation and supervision mechanisms, but no comprehensive statute governed surrogacy."
      },
      {
        "title": "First Bans and Restrictions",
        "content": "In 2013, surrogacy for foreign homosexual couples and single parents was prohibited; a 2015 blanket ban on commercial surrogacy ended foreign‑client participation and limited embryo entry to research."
      },
      {
        "title": "Surrogacy (Regulation) Bills",
        "content": "Bills introduced in 2016, re‑passed in 2019 and revised in 2020 progressively shifted the model to altruistic surrogacy, tightened surrogate eligibility (age, parity, kinship), and restricted intended parents to Indian heterosexual married couples, later extending limited access to widowed/divorced women."
      },
      {
        "title": "Surrogacy (Regulation) Act 2021",
        "content": "The Act codifies the altruistic‑only framework, enforces reimbursement‑only payment to surrogates, defines infertility criteria, and mandates oversight by the Ministry of Health and Family Welfare."
      },
      {
        "title": "Economic Impact and Concerns",
        "content": "Estimates range from $400 million to $2 billion annually; concerns include exploitation, health risks to surrogates, and cross‑border citizenship disputes that motivated regulatory tightening."
      }
    ],
    "keywords": [
      "surrogacy",
      "commercial surrogacy",
      "altruistic surrogacy",
      "assisted reproductive technology",
      "ART",
