  {
    "id": "6aa44022-23f4-457c-b91e-6383583c659a",
    "source": "https://en.wikipedia.org/wiki/Parsi_Marriage_and_Divorce_Act,_1936",
    "title": "Parsi Marriage and Divorce Act, 1936",
    "summary": "The Parsi Marriage and Divorce Act, 1936, enacted by the Imperial Legislative Council, provides a dedicated legal framework for the solemnization, registration, and dissolution of marriages among Parsis, defined as followers of the Zoroastrian faith. It sets age limits, requires priestly officiation and free consent, and outlines grounds for divorce, including adultery, cruelty, desertion, insanity, conversion, and mutual consent. The Act also empowers specialised Parsi matrimonial courts to adjudicate custody, alimony, maintenance, and property matters, with appeals to the High Court. While praised for preserving community customs, the law has faced criticism for outdated provisions and gender inequities, prompting ongoing reforms.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Parsi Marriage and Divorce Act, 1936"
      },
      {
        "type": "legislature",
        "name": "Imperial Legislative Council"
      },
      {
        "type": "religion",
        "name": "Zoroastrianism"
      },
      {
        "type": "community",
        "name": "Parsi community"
      },
      {
        "type": "person",
        "name": "Parsi priest (mobed)"
      },
      {
        "type": "court",
        "name": "Parsi matrimonial courts"
      },
      {
        "type": "court",
        "name": "High Court"
      },
      {
        "type": "court",
        "name": "Supreme Court of India"
      },
      {
        "type": "concept",
        "name": "polygamy"
      },
      {
        "type": "concept",
        "name": "mutual consent divorce"
      }
    ],
    "sections": [
      {
        "title": "Background",
        "content": "The Act was introduced to address the unique customs of Parsis that were not adequately covered by general Indian marriage laws, consolidating earlier regulations into a comprehensive statute."
      },
      {
        "title": "Solemnization of Marriage",
        "content": "A valid Parsi marriage must be performed by a mobed in the presence of at least two witnesses, with minimum ages of 21 for males and 18 for females, and must be based on free consent."
      },
      {
        "title": "Conditions for Validity",
        "content": "Both parties must be Parsis at the time of marriage, monogamous, and not within prohibited degrees of relationship; any violation renders the marriage void."
      },
      {
        "title": "Registration of Marriage",
        "content": "All Parsi marriages are required to be registered with a designated registrar; the issued certificate serves as legal proof, and non‑registration attracts penalties."
      },
      {
        "title": "Divorce and Judicial Separation",
        "content": "The Act enumerates grounds for divorce or judicial separation, including adultery, cruelty, two‑year desertion, unsound mind, conversion, and mutual consent."
      },
      {
        "title": "Special Divorce Provisions",
        "content": "If a spouse fails to cohabit for one year after a court order, the other spouse may seek divorce, with the court mandated to attempt reconciliation before granting decree."
      },
      {
        "title": "Custody, Alimony, and Maintenance",
        "content": "Courts determine child custody based on welfare, and may award permanent alimony or maintenance according to the financial needs and capacities of the parties, with provisions for revision."
      },
      {
        "title": "Inheritance and Property Rights",
        "content": "While primarily a matrimonial law, the Act interacts with Parsi personal law on inheritance, influencing spousal and children's rights after divorce or death."
      },
      {
        "title": "Jurisdiction and Enforcement",
        "content": "Special Parsi matrimonial courts handle cases under the Act; appeals lie with the High Court, ensuring a dedicated judicial channel for Parsi matrimonial matters."
      },
      {
        "title": "Criticism and Reforms",
        "content": "Critiques focus on outdated, gender‑biased clauses and procedural inefficiencies, leading to calls for amendments to enhance gender neutrality and expedite dispute resolution."
      },
      {
        "title": "Application",
        "content": "The Act remains applicable in India, Pakistan, and Bangladesh as successor states of the former British Indian Empire."
      }
    ],
