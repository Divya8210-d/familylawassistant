  },
  {
    "id": "ae12ba63-034f-4c68-ad92-cdc8b83573a6",
    "source": "https://en.wikisource.org/wiki/Guardians_and_Wards_Act,_1890",
    "title": "Guardians and Wards Act, 1890 – Key Provisions on Guardianship",
    "summary": "The Guardians and Wards Act, 1890 empowers courts to issue orders regarding the appointment and removal of guardians for minors. When deciding guardianship, the court must consider the minor's age, sex, religion, the proposed guardian's character and capacity, kinship proximity, the wishes of any deceased parent, and existing relationships, with the minor's welfare being paramount. Certain categories of persons are excluded from appointment as guardians, and the court may compel the return of a ward who leaves a guardian's custody. The Act also authorises the court to order the production of a minor and to dictate custody arrangements. A guardian's authority ceases automatically when the ward attains eighteen years of age or gets married.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Guardians and Wards Act, 1890"
      },
      {
        "type": "institution",
        "name": "Court"
      },
      {
        "type": "concept",
        "name": "Minor"
      },
      {
        "type": "concept",
        "name": "Guardian"
      },
      {
        "type": "concept",
        "name": "Ward"
      },
      {
        "type": "concept",
        "name": "Custody"
      },
      {
        "type": "concept",
        "name": "Welfare of the minor"
      }
    ],
    "sections": [
      {
        "title": "Section 7 – Power of Court to Make Order as to Guardianship",
        "content": "Grants the court authority to issue any order necessary for the appointment, removal, or regulation of a guardian for a minor."
      },
      {
        "title": "Section 17 – Matters to be Considered by the Court",
        "content": "The court must examine the minor's age, sex, religion; the character and capacity of the proposed guardian; closeness of kinship; wishes of any deceased parent; and existing relations with the minor, with the minor's welfare being the paramount consideration."
      },
      {
        "title": "Section 19 – Guardians Not to be Appointed in Certain Cases",
        "content": "Specifies categories of persons who are disqualified from being appointed as guardians, such as persons of unsound mind, insolvent individuals, or those convicted of certain offences."
      },
      {
        "title": "Section 25 – Title of Guardian to Custody of Ward",
        "content": "Allows the court to order the return of a ward who leaves the custody of the appointed guardian without lawful cause."
      },
      {
        "title": "Section 26 – Power to Make Order for Production of Minor and His Custody",
        "content": "Empowers the court to direct that a minor be produced before it and to determine the appropriate custody arrangement."
      },
      {
        "title": "Section 44 – Cessation of Authority of Guardian",
        "content": "Provides that a guardian's authority automatically ends when the ward reaches the age of eighteen years or gets married."
      }
    ],
