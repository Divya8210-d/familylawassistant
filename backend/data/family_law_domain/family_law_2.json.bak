  {
    "id": "7f93eb85-7a0b-4b97-954d-41432a29f5a6",
    "source": "https://en.wikisource.org/wiki/Indian_Divorce_Act,_1869",
    "title": "Key Provisions of the Indian Divorce Act, 1869",
    "summary": "The Indian Divorce Act, 1869 governs divorce among Christians in India, outlining specific grounds for dissolution of marriage such as adultery, bigamy, and cruelty. It prescribes the procedural requirement that a petition for divorce be filed in a District Court or High Court. The Act provides for interim alimony (pendente lite) and permanent alimony, either as periodic payments or a lump sum. Custody, maintenance, and education of children are addressed under Section 41. An amendment introduced Section 10A, allowing divorce by mutual consent after a two‑year separation.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Indian Divorce Act, 1869"
      },
      {
        "type": "Court",
        "name": "District Court"
      },
      {
        "type": "Court",
        "name": "High Court"
      },
      {
        "type": "Concept",
        "name": "Alimony pendente lite"
      },
      {
        "type": "Concept",
        "name": "Permanent alimony"
      },
      {
        "type": "Concept",
        "name": "Custody of children"
      }
    ],
    "sections": [
      {
        "title": "Section 10 – Grounds for Dissolution of Marriage",
        "content": "Specifies admissible grounds such as adultery, bigamy with adultery, marriage to another woman, rape, sodomy, bestiality, desertion for two years or more, and cruelty."
      },
      {
        "title": "Section 10A – Divorce by Mutual Consent",
        "content": "Allows spouses to jointly file a divorce petition after a continuous separation of two years, reflecting a modernized, consensual approach."
      },
      {
        "title": "Section 17 – Petition for Dissolution",
        "content": "Mandates that a divorce petition be presented before the appropriate District Court or High Court for consideration."
      },
      {
        "title": "Section 22 – Alimony Pendente Lite",
        "content": "Provides for interim maintenance to be awarded to the petitioner during the pendency of the divorce proceedings."
      },
      {
        "title": "Section 36 – Permanent Alimony",
        "content": "Authorizes courts to order either periodic payments or a lump‑sum settlement to support the divorced spouse permanently."
      },
      {
        "title": "Section 41 – Custody, Maintenance and Education of Children",
        "content": "Addresses the welfare of minor children, including custody arrangements, financial maintenance, and educational provisions."
      }
    ],
    "keywords": [
