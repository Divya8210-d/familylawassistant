      "Mehr",
      "Dower",
      "Triple talaq",
      "Dissolution of marriage",
      "Guardianship",
      "Wakf",
      "Cognisable offence",
      "Non‑bailable",
      "Maintenance",
      "Marriage",
      "Custom override"
    ]
  },
  {
    "id": "716b59f5-fc1d-4ba0-ab4b-5651809464e3",
    "source": "https://en.wikisource.org/wiki/Hindu_Succession_Act,_1956",
    "title": "Hindu Succession Act, 1956",
    "summary": "The Hindu Succession Act, 1956 governs the devolution of property among Hindus. It establishes the hierarchy of heirs for male Hindus, designating Class I heirs (widow, mother, son, daughter) as primary successors, followed by Class II heirs, agnates and cognates. For female Hindus, the Act treats their property as absolute and provides that succession follows the heirs of their husband, then their own parents, and finally the heirs of the husband's father. The 2005 amendment made daughters coparceners by birth, granting them the same rights as sons in coparcenary property and allowing them to seek partition, thereby repealing the earlier restriction in Section 23.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Hindu Succession Act, 1956"
      },
      {
        "type": "Section",
        "name": "Section 6"
      },
      {
        "type": "Section",
        "name": "Section 8"
      },
      {
        "type": "Section",
        "name": "Section 14"
      },
      {
        "type": "Section",
        "name": "Section 15"
      },
      {
        "type": "Section",
        "name": "Section 23"
      },
      {
        "type": "Amendment",
        "name": "2005 Amendment to Section 6"
      },
      {
        "type": "Concept",
        "name": "Coparcenary property"
      },
      {
        "type": "Concept",
        "name": "Class I heirs"
      },
      {
        "type": "Concept",
        "name": "Class II heirs"
      }
    ],
    "sections": [
      {
        "title": "Section 6 – Devolution of Interest in Coparcenary Property (as amended 2005)",
        "content": "Originally, daughters were excluded from coparcenary rights. The 2005 amendment declares daughters coparceners by birth, giving them the same entitlement to ancestral property as sons, including the right to seek partition."
      },
      {
        "title": "Section 8 – General Rules of Succession for Males",
        "content": "Specifies the order of inheritance for a male Hindu: Class I heirs (widow, mother, son, daughter) inherit first; in their absence, Class II heirs succeed; thereafter, agnates and finally cognates."
      },
      {
        "title": "Section 14 – Property of a Female Hindu",
        "content": "Declares that the property owned by a female Hindu is her absolute (self-owned) property, free from any external claim."
      },
      {
        "title": "Section 15 – General Rules of Succession for Females",
        "content": "Sets the succession hierarchy for a female Hindu: first the heirs of her husband, then her own parents, and finally the heirs of her husband’s father."
      },
      {
        "title": "Section 23 – Repealed Provision (pre‑2005)",
        "content": "Previously barred daughters from participation in the partition of a dwelling house; this provision was repealed by the 2005 amendment."
      }
    ],
    "keywords": [
