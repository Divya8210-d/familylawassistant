      {
        "type": "concept",
        "name": "settlement"
      },
      {
        "type": "person",
        "name": "friend or social worker (as representative)"
      }
    ],
    "sections": [
      {
        "title": "Section 3 – Establishment of Family Courts",
        "content": "State Governments may, by notification, constitute Family Courts to handle family disputes, thereby creating a specialized forum for speedy and amicable resolution."
      },
      {
        "title": "Section 7 – Jurisdiction of Family Courts",
        "content": "Family Courts have jurisdiction over a comprehensive list of matrimonial and family matters, including nullity of marriage, restitution of conjugal rights, judicial separation, dissolution of marriage, maintenance, guardianship, custody, legitimacy and property disputes between spouses."
      },
      {
        "title": "Section 9 – Duty to Make Efforts for Settlement",
        "content": "Before proceeding to adjudication, the Family Court must first endeavour to bring the parties to a settlement, using mediation or other conciliatory methods."
      },
      {
        "title": "Section 10 – Procedure",
        "content": "The procedural law applicable is the Civil Procedure Code, subject to modifications as prescribed by the Act; the court may also adopt any suitable procedure to ensure swift disposal of cases."
      },
      {
        "title": "Section 13 – Restriction on Legal Representation",
        "content": "Parties are generally not permitted to be represented by lawyers; instead, they may be assisted by a friend or a social worker, emphasizing informal and accessible dispute resolution."
      }
    ],
