    ]
  },
  {
    "id": "7f35500a-173d-4013-821d-b01595129127",
    "source": "https://en.wikisource.org/wiki/Family_Courts_Act,_1984",
    "title": "Family Courts Act, 1984 – Establishment, Jurisdiction and Procedural Framework",
    "summary": "The Family Courts Act, 1984 empowers State Governments to constitute Family Courts for the expeditious disposal of family disputes. It delineates the courts' jurisdiction over matters such as nullity of marriage, restitution of conjugal rights, judicial separation, dissolution, maintenance, guardianship, custody, legitimacy and property disputes between spouses. The Act mandates that courts first attempt settlement through mediation before adjudication. Procedural matters are governed by the Civil Procedure Code with modifications, and the Act restricts legal representation, permitting parties to be assisted by a friend or social worker.",
    "law_type": "family_law",
    "entities": [
