  {
    "id": "a975485d-ce67-4153-a4d8-0af7d13e8b30",
    "source": "https://en.wikisource.org/wiki/Protection_of_Women_from_Domestic_Violence_Act,_2005",
    "title": "Protection of Women from Domestic Violence Act, 2005",
    "summary": "The Protection of Women from Domestic Violence Act, 2005 defines domestic violence to include physical, sexual, emotional, economic abuse and dowry harassment. It empowers aggrieved women in a domestic relationship to approach a magistrate for protection, residence, monetary, custody and compensation orders. The Act guarantees the right of a woman to reside in a shared household and provides mechanisms for enforcement, including penalties for breach of protection orders.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Protection of Women from Domestic Violence Act, 2005"
      },
      {
        "type": "institution",
        "name": "Magistrate"
      },
      {
        "type": "concept",
        "name": "Domestic Violence"
      },
      {
        "type": "person",
        "name": "Aggrieved Woman"
      },
      {
        "type": "person",
        "name": "Respondent"
      },
      {
        "type": "concept",
        "name": "Protection Order"
      },
      {
        "type": "concept",
        "name": "Residence Order"
      },
      {
        "type": "concept",
        "name": "Monetary Relief"
      },
      {
        "type": "concept",
        "name": "Compensation Order"
      }
    ],
    "sections": [
      {
        "title": "Section 3 – Definition of Domestic Violence",
        "content": "Domestic violence includes physical abuse, sexual abuse, verbal and emotional abuse, economic abuse, dowry harassment and any conduct threatening the aggrieved person."
      },
      {
        "title": "Section 12 – Application to Magistrate",
        "content": "An aggrieved woman may apply to the magistrate for protection orders, residence orders, monetary relief, custody orders and compensation orders."
      },
      {
        "title": "Section 17 – Right to Reside in Shared Household",
        "content": "Every woman in a domestic relationship has a legal right to reside in the shared household."
      },
      {
        "title": "Section 18 – Protection Orders",
        "content": "The magistrate may prohibit the respondent from committing acts of domestic violence, entering the aggrieved woman's workplace, or communicating with her."
      },
      {
        "title": "Section 19 – Residence Orders",
        "content": "A residence order may direct the respondent to vacate the shared household to ensure the safety of the aggrieved woman."
      },
      {
        "title": "Section 20 – Monetary Relief",
        "content": "Provides for payment of medical expenses, loss of earnings, maintenance for the aggrieved woman and children, and compensation for property damage."
      },
      {
        "title": "Section 21 – Custody Orders",
        "content": "The magistrate can issue orders concerning the custody of minor children in the interest of the aggrieved woman."
      },
      {
        "title": "Section 22 – Compensation Orders",
        "content": "Allows the magistrate to award compensation to the aggrieved woman for any harm suffered due to domestic violence."
      },
      {
        "title": "Section 31 – Penalty for Breach of Protection Order",
        "content": "Any person who contravenes a protection order may be punished with imprisonment up to one year or a fine."
      }
    ],
    "keywords": [
