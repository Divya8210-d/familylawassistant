      },
      {
        "type": "court",
        "name": "High Courts of India"
      },
      {
        "type": "legal principle",
        "name": "Doctrine of speedy justice"
      }
    ],
    "sections": [
      {
        "title": "Principle of Non‑Stay for Maintenance Orders",
        "content": "The Court reaffirmed that Section 125 orders are meant to provide immediate financial relief and must not be subject to interim stays that could defeat their purpose."
      },
      {
        "title": "Definition of \"Very Special Reasons\"",
        "content": "Only when the applicant can demonstrate clear abuse of process, manifest injustice, or an irreparable harm unrelated to the maintenance claim may a stay be considered."
      },
      {
        "title": "Impact on Women and Children",
        "content": "The judgment underscores the vulnerability of women and children dependent on maintenance, aligning with the constitutional guarantee of life and livelihood."
      },
      {
        "title": "Procedural Guidelines for Appellate Courts",
        "content": "Lower courts are directed to scrutinise each stay application rigorously, record detailed reasons for any departure from the general rule, and prioritize speedy disposal."
      },
      {
        "title": "Future Outlook",
        "content": "The decision is likely to influence subsequent case law, prompting a more consistent application of Section 125 across jurisdictions and reducing litigation delays."
      }
    ],
