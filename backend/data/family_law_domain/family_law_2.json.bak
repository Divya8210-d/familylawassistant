  {
    "id": "48499aac-a61f-4447-b557-17155cc42ed7",
    "source": "https://en.wikisource.org/wiki/Dowry_Prohibition_Act,_1961",
    "title": "Dowry Prohibition Act, 1961",
    "summary": "The Dowry Prohibition Act, 1961 defines dowry as any property or valuable security given in connection with marriage and criminalises its giving, taking, or demanding. It prescribes imprisonment of up to five years and a fine for the giver or taker, and up to two years imprisonment with a fine for those who demand dowry. The Act bars advertisements for dowry, mandates that any dowry received is for the benefit of the wife or her heirs, and provides for the appointment of Dowry Prohibition Officers to enforce its provisions. It also references the related offence under Section 498A of the Indian Penal Code, which penalises cruelty linked to dowry demands.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Dowry Prohibition Act, 1961"
      },
      {
        "type": "Section",
        "name": "Section 2 – Definition of dowry"
      },
      {
        "type": "Section",
        "name": "Section 3 – Penalty for giving or taking dowry"
      },
      {
        "type": "Section",
        "name": "Section 4 – Penalty for demanding dowry"
      },
      {
        "type": "Section",
        "name": "Section 4A – Ban on advertisement for dowry"
      },
      {
        "type": "Section",
        "name": "Section 6 – Dowry for benefit of wife or heirs"
      },
      {
        "type": "Section",
        "name": "Section 8B – Dowry Prohibition Officers"
      },
      {
        "type": "Act",
        "name": "Indian Penal Code"
      },
      {
        "type": "Section",
        "name": "Section 498A IPC – Cruelty related to dowry demand"
      },
      {
        "type": "Concept",
        "name": "Dowry"
      },
      {
        "type": "Concept",
        "name": "Cruelty"
      },
      {
        "type": "Concept",
        "name": "Dowry Prohibition Officer"
      }
    ],
    "sections": [
      {
        "title": "Definition of Dowry (Section 2)",
        "content": "Dowry is defined as any property or valuable security given or agreed to be given in connection with a marriage."
      },
      {
        "title": "Penalty for Giving or Taking Dowry (Section 3)",
        "content": "Any person who gives or takes dowry faces imprisonment for up to five years and a fine of ₹15,000 or the value of the dowry, whichever is higher."
      },
      {
        "title": "Penalty for Demanding Dowry (Section 4)",
        "content": "Anyone who demands dowry is punishable with imprisonment ranging from six months to two years and a fine up to ₹10,000."
      },
      {
        "title": "Ban on Dowry Advertisements (Section 4A)",
        "content": "The Act prohibits any advertisement that promotes or solicits dowry."
      },
      {
        "title": "Beneficial Ownership of Dowry (Section 6)",
        "content": "Any dowry received must be used solely for the benefit of the wife or her legal heirs."
      },
      {
        "title": "Dowry Prohibition Officers (Section 8B)",
        "content": "The government may appoint Dowry Prohibition Officers to investigate and enforce the provisions of the Act."
      },
      {
        "title": "Related Cruelty Provision (Section 498A, IPC)",
        "content": "A husband or his relatives who subject a wife to cruelty for dowry demands are liable to imprisonment of up to three years under Section 498A of the Indian Penal Code."
      }
    ],
    "keywords": [
