      "family law",
      "legislative advisory",
      "jurisprudence"
    ]
  },
  {
    "id": "39f0ca0c-259b-46c4-bc6c-9c859d5fe9bf",
    "source": "https://en.wikisource.org/wiki/Hindu_Marriage_Act,_1955",
    "title": "Hindu Marriage Act, 1955 – Key Provisions on Marriage, Divorce and Maintenance",
    "summary": "The Hindu Marriage Act, 1955 governs the solemnisation of marriages between Hindus, stipulating that parties must be unmarried, capable of giving consent, of requisite age (21 for males, 18 for females), and not within prohibited degrees of relationship. It outlines both fault-based and mutual‑consent grounds for divorce, including cruelty, desertion, conversion, mental disorder and others. The Act provides for interim maintenance (pendente lite), permanent alimony, child custody, restitution of conjugal rights and judicial separation, thereby covering the full spectrum of matrimonial disputes under Indian family law.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Hindu Marriage Act, 1955"
      },
      {
        "type": "Concept",
        "name": "Marriage"
      },
      {
        "type": "Concept",
        "name": "Divorce"
      },
      {
        "type": "Concept",
        "name": "Mutual Consent Divorce"
      },
      {
        "type": "Concept",
        "name": "Maintenance"
      },
      {
        "type": "Concept",
        "name": "Alimony"
      },
      {
        "type": "Concept",
        "name": "Child Custody"
      },
      {
        "type": "Concept",
        "name": "Restitution of Conjugal Rights"
      },
      {
        "type": "Concept",
        "name": "Judicial Separation"
      },
      {
        "type": "Concept",
        "name": "Prohibited Relationship"
      }
    ],
    "sections": [
      {
        "title": "Section 5 – Conditions for a Hindu Marriage",
        "content": "A marriage may be solemnised between two Hindus only if neither has a living spouse, both are capable of giving valid consent, the groom is at least 21 years old and the bride at least 18 years old, and they are not within the prohibited degrees of relationship."
      },
      {
        "title": "Section 13 – Divorce on Fault Grounds",
        "content": "Either party may file for divorce on grounds such as cruelty, desertion of at least two years, conversion to another religion, mental disorder, leprosy, communicable venereal disease, renunciation of worldly life, or non‑appearance of the spouse for seven years."
      },
      {
        "title": "Section 13B – Divorce by Mutual Consent",
        "content": "Both spouses may jointly petition for dissolution of marriage after living separately for a period of one year or more, provided they have been reconciled or have mutually agreed to the divorce."
      },
      {
        "title": "Section 24 – Maintenance Pendente Lite",
        "content": "During the pendency of divorce or judicial separation proceedings, the court may order temporary maintenance for the wife, children, or dependent husband."
      },
      {
        "title": "Section 25 – Permanent Alimony and Maintenance",
        "content": "After a decree of divorce or judicial separation, the court may award permanent alimony and maintenance to the wife, children, or dependent husband, taking into account the parties' means and conduct."
      },
      {
        "title": "Section 26 – Custody of Children",
        "content": "The court may order custody, access, and residence of children, considering the child's welfare, the parents' ability to provide for the child, and any other relevant factor."
      },
      {
        "title": "Section 9 – Restitution of Conjugal Rights",
        "content": "If either spouse withdraws from cohabitation without lawful excuse, the other may file a petition for restitution of conjugal rights, directing the errant spouse to resume marital duties."
      },
      {
        "title": "Section 10 – Judicial Separation",
        "content": "Either spouse may obtain a decree of judicial separation, which suspends cohabitation and marital obligations without dissolving the marriage, allowing for separate residences and possible maintenance."
      }
    ],
    "keywords": [
      "marriage",
      "divorce",
      "mutual consent",
      "maintenance",
      "alimony",
      "child custody",
      "prohibited relationship",
      "mental disorder",
      "cruelty",
      "restitution of conjugal rights",
      "judicial separation",
      "Hindu personal law",
      "age of consent"
    ]
  },
  {
    "id": "3e32b8d3-7efe-4aef-a11f-7f489e883629",
    "source": "https://en.wikisource.org/wiki/Special_Marriage_Act,_1954",
    "title": "Special Marriage Act, 1954 – Key Provisions",
    "summary": "The Special Marriage Act, 1954 provides a secular framework for marriage in India, allowing individuals of any religion to marry under a uniform legal regime. It sets essential conditions for a valid marriage, including age limits, monogamy, and the prohibition of prohibited degrees of relationship. The Act enumerates specific grounds for divorce, both general and gender‑specific, and allows for mutual consent divorce after separation. It also outlines provisions for interim and permanent alimony, as well as custody, maintenance, and education of minor children.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Special Marriage Act, 1954"
      },
      {
        "type": "Section",
        "name": "Section 4 – Conditions of marriage"
      },
      {
        "type": "Section",
        "name": "Section 27 – Grounds for divorce"
      },
      {
        "type": "Section",
        "name": "Section 27A – Divorce by wife on husband's sexual offences"
      },
      {
        "type": "Section",
        "name": "Section 28 – Divorce by mutual consent"
      },
      {
        "type": "Section",
        "name": "Section 36 – Alimony pendente lite"
      },
      {
        "type": "Section",
        "name": "Section 37 – Permanent alimony and maintenance"
      },
      {
        "type": "Section",
        "name": "Section 38 – Custody, maintenance and education of minor children"
      },
      {
        "type": "Concept",
        "name": "Monogamy"
      },
      {
        "type": "Concept",
        "name": "Prohibited degrees of relationship"
      }
    ],
    "sections": [
      {
        "title": "Conditions for a valid marriage (Sec. 4)",
        "content": "Neither party may have a living spouse, both must be capable of giving valid consent, the male must be at least 21 years old and the female at least 18 years, and the parties must not be within the prohibited degrees of relationship as defined under the Act."
      },
      {
        "title": "Grounds for divorce (Sec. 27)",
        "content": "Divorce may be granted on any of the following grounds: adultery, desertion for a continuous period of two or more years, imprisonment for seven or more years, cruelty, mental disorder, leprosy, venereal disease, or renunciation of the Hindu religion."
      },
      {
        "title": "Gender‑specific divorce ground (Sec. 27A)",
        "content": "A wife may obtain divorce if the husband is guilty of rape, sodomy, or bestiality."
      },
      {
        "title": "Divorce by mutual consent (Sec. 28)",
        "content": "The parties may jointly file for divorce after a separation of at least one year, provided they have been living apart and have reconciled their differences."
      },
      {
        "title": "Interim alimony (Sec. 36)",
        "content": "The court may award alimony pendente lite to the petitioner during the pendency of divorce proceedings."
      },
      {
        "title": "Permanent alimony and maintenance (Sec. 37)",
        "content": "The court may order permanent alimony and maintenance to the spouse who is unable to maintain herself/himself after the divorce decree."
      },
      {
        "title": "Custody, maintenance and education of minor children (Sec. 38)",
        "content": "The court shall determine the custody, maintenance, and education of minor children in the best interests of the child, taking into account the welfare of both parents."
      }
    ],
    "keywords": [
