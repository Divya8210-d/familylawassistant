  {
    "id": "00e6805b-774e-4864-931c-2159d60407b1",
    "source": "https://en.wikisource.org/wiki/Hindu_Minority_and_Guardianship_Act,_1956",
    "title": "Hindu Minority and Guardianship Act, 1956",
    "summary": "The Act defines a minor as any person who has not completed eighteen years of age. It establishes the father as the primary natural guardian of a Hindu minor, with the mother succeeding thereafter and serving as the ordinary custodian for children under five. The legislation delineates the powers of natural guardians, permitting them to act for the minor’s benefit but barring the mortgage, charge or alienation of immovable property without court approval. A testamentary guardian may be appointed to manage the minor's property through a will. Throughout all proceedings, the welfare of the minor is mandated as the paramount consideration.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Hindu Minority and Guardianship Act, 1956"
      },
      {
        "type": "concept",
        "name": "Minor"
      },
      {
        "type": "concept",
        "name": "Natural guardian"
      },
      {
        "type": "person",
        "name": "Father"
      },
      {
        "type": "person",
        "name": "Mother"
      },
      {
        "type": "concept",
        "name": "Testamentary guardian"
      },
      {
        "type": "concept",
        "name": "Welfare of minor"
      }
    ],
    "sections": [
      {
        "title": "Definitions",
        "content": "Section 4 defines a minor as a person who has not completed eighteen years of age."
      },
      {
        "title": "Natural Guardians of a Hindu Minor",
        "content": "Section 6 declares the father as the natural guardian; if the father is absent, the mother assumes that role, and for children below five years, the mother is the ordinary custodian."
      },
      {
        "title": "Natural Guardianship of an Adopted Son",
        "content": "Section 7 provides that the natural guardian of an adopted Hindu son is the same as for a biological son."
      },
      {
        "title": "Powers of Natural Guardian",
        "content": "Section 8 empowers the natural guardian to perform acts for the minor’s benefit but prohibits mortgaging, charging, or alienating immovable property without court permission."
      },
      {
        "title": "Guardianship by Testamentary Guardian",
        "content": "Section 9 allows a testamentary guardian to manage the minor’s property as per the terms of a will."
      },
      {
        "title": "Welfare of Minor Paramount",
        "content": "Section 13 mandates that in all proceedings concerning a minor, the welfare of the minor shall be the paramount consideration."
      }
    ],
    "keywords": [
      "minor",
      "natural guardian",
      "father",
