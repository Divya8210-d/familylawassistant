      },
      {
        "type": "person",
        "name": "Justice P.S. Narasimha"
      },
      {
        "type": "person",
        "name": "Mukul Rohatgi"
      },
      {
        "type": "person",
        "name": "Rakesh Dwivedi"
      },
      {
        "type": "act",
        "name": "Special Marriage Act"
      },
      {
        "type": "concept",
        "name": "Indian Constitution"
      },
      {
        "type": "concept",
        "name": "Articles 14, 19 and 21"
      },
      {
        "type": "case",
        "name": "Navtej Singh Johar v. Union of India"
      },
      {
        "type": "case",
        "name": "Justice K.S. Puttaswamy (Retd) v. Union of India"
      },
      {
        "type": "case",
        "name": "Anuj Garg & Ors v. Hotel Association of India"
      },
      {
        "type": "act",
        "name": "Hindu Widows' Right to Remarry Act, 1860"
      }
    ],
    "sections": [
      {
        "title": "Relief Sought",
        "content": "Petitioners request a declaration that the right to marry is a fundamental right for LGBTQIA+ persons under Articles 14, 19 and 21, and that this right be implemented through an inclusive interpretation of the Special Marriage Act."
      },
      {
        "title": "Constitutional Basis",
        "content": "Rohatgi grounds the claim in the Preamble and the guarantee of equality, liberty, and fraternity enshrined in Articles 14, 19 and 21, asserting that these rights extend to all individuals irrespective of sexual orientation."
      },
      {
        "title": "Precedents Cited",
        "content": "Key judgments referenced include Navtej Singh Johar (decriminalisation of homosexuality), Justice K.S. Puttaswamy (Right to Privacy), and Anuj Garg (equality and anti‑discrimination principles)."
      },
      {
        "title": "Comparative Jurisprudence",
        "content": "The argument draws on global developments in the United States, United Kingdom and other jurisdictions where same‑sex marriage has been legally recognised, to illustrate evolving legal norms."
      },
      {
        "title": "Counter‑Arguments and Response",
        "content": "The Union contended that the petitions represent an elite, urban viewpoint and that popular will opposes same‑sex marriage; Rohatgi rebutted that constitutional rights are not subject to popular sentiment and that law can lead societal change."
      },
      {
        "title": "Evolution of Marriage Law",
        "content": "Rohatgi highlighted historical changes such as the abolition of child marriage and the Hindu Widows' Right to Remarry Act, underscoring that the concept of marriage has been re‑interpreted over time."
      }
    ],
