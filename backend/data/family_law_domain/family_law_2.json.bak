    "sections": [
      {
        "title": "Constitutional and Statutory Requirement",
        "content": "Article 22(1) of the Constitution and Section 47 of BNSS 2023 mandate that an arrestee must be informed of the grounds of arrest in writing, in a language they understand."
      },
      {
        "title": "Exception for Flagrante Delicto",
        "content": "In cases of immediate apprehension, oral communication at the time of arrest is allowed, provided written grounds are furnished within a reasonable time, and no later than two hours before the magistrate's remand hearing."
      },
      {
        "title": "Consequences of Non‑Compliance",
        "content": "If written grounds are not supplied within the stipulated timeframe, the arrest and any subsequent remand are deemed illegal, obligating the release of the detained person."
      },
      {
        "title": "Duty to Inform Relatives",
        "content": "Section 48 of BNSS 2023 requires police to inform the arrested person’s relatives or nominated persons about the arrest and place of detention."
      },
      {
        "title": "Impact on Ongoing Proceedings",
        "content": "The Supreme Court dismissed the appeals, upheld interim bail in related matters, and directed that these principles govern future arrests to ensure uniformity."
      }
    ],
