  {
    "id": "864e8b5a-eccc-47c4-a391-b1995ccfecd7",
    "source": "https://en.wikisource.org/wiki/Prohibition_of_Child_Marriage_Act,_2006",
    "title": "Prohibition of Child Marriage Act, 2006",
    "summary": "The Act defines a child as a male below 21 years of age and a female below 18 years of age. It declares child marriages voidable, permitting a child to obtain an annulment within two years of attaining majority. Courts are empowered to grant injunctions to prevent child marriages and to impose imprisonment of up to two years or a fine on adult males, officiants, or promoters who facilitate such marriages. Marriages undertaken by force or against the child's will are deemed void. Children born from void or voidable marriages are treated as legitimate.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Prohibition of Child Marriage Act, 2006"
      },
      {
        "type": "Office",
