    ]
  },
  {
    "id": "5745445f-0406-476f-95e0-0234325422ba",
    "source": "http://www.indiankanoon.org:80/doc/1000016/",
    "title": "Citicorp Maruti Finance Ltd. v. S. Vijayalaxmi – Illegal repossession of a financed vehicle",
    "summary": "The National Consumer Disputes Redressal Commission held that a borrower who purchases a vehicle on loan remains the owner of the vehicle, even when the loan is secured by the vehicle. Consequently, a financier cannot take possession of the vehicle by force; repossession must follow due legal process. The Court distinguished a hire‑purchase agreement from a simple loan, emphasizing that the latter does not transfer ownership to the lender. It condemned harassment by agents of the financier and directed that any repossession must be in compliance with statutory protections. The judgment reinforced consumer rights and the rule of law in financial transactions involving motor vehicles.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Motor Vehicles Act, 1939"
      },
      {
        "type": "act",
        "name": "Hire Purchase Act, 1972"
      },
      {
        "type": "act",
        "name": "State Financial Corporations Act, 1951"
      },
      {
        "type": "act",
        "name": "Indian Penal Code, 1860"
      },
      {
        "type": "court",
        "name": "National Consumer Disputes Redressal Commission (NCDRC)"
      },
      {
        "type": "person",
        "name": "Citicorp Maruti Finance Ltd."
      },
      {
        "type": "person",
        "name": "S. Vijayalaxmi"
      },
      {
        "type": "judge",
        "name": "M.B. Shah"
      },
      {
        "type": "judge",
        "name": "K G Member"
      },
      {
        "type": "judge",
        "name": "R Rao"
      }
    ],
    "sections": [
      {
        "title": "Ownership under Hire‑Purchase and Loan Agreements",
        "content": "When a consumer finances a vehicle, the vehicle is registered in the consumer’s name and the consumer remains the legal owner, unless a specific transfer of ownership is effected."
      },
      {
        "title": "Prohibition of Forceful Repossession",
        "content": "Financiers may not repossess a vehicle by using musclemen or any extrajudicial means; repossession must be carried out only after a lawful judicial process."
      },
      {
        "title": "Distinction Between Hire‑Purchase and Simple Loan",
        "content": "A hire‑purchase agreement gives the hirer an option to purchase after paying installments, whereas a simple loan merely provides credit with the vehicle as security; the latter does not confer ownership to the lender."
      },
      {
        "title": "Consumer Protection Against Harassment",
        "content": "The Court condemned harassment, torture or threats by agents of the financier and called for streamlined, lawful mechanisms for recovery of dues."
      },
      {
        "title": "Procedural Requirements for Settlement and Recovery",
        "content": "Any settlement offer must be communicated clearly, with reasonable time for compliance; arbitrary deadlines that are impossible to meet are invalid."
      }
    ],
    "keywords": [
      "hire purchase",
      "loan transaction",
      "consumer rights",
      "vehicle repossession",
      "ownership",
      "security interest",
      "NCDRC",
      "consumer protection",
      "harassment",
      "settlement letter",
      "legal process",
      "motor vehicle"
    ]
  },
  {
    "id": "42b1a1eb-871e-4749-bef3-377ad69a0137",
    "source": "http://indiankanoon.org:80/doc/1000027/",
    "title": "N. Desaiah & Ors. v. Government of Andhra Pradesh (1966)",
    "summary": "The petitioners, officers of the Public Health Department, filed a writ petition under Article 226 of the Constitution seeking a mandamus to restrain the State Government of Andhra Pradesh from implementing a Central Government decision that allowed Assistant Surgeons from the erstwhile Hyderabad State to count their service before 1‑Nov‑1956 for promotion to Assistant Director of Public Health. The case centered on the interpretation of Sections 115 and 116 of the States Reorganisation Act, 1956, concerning the integration and seniority of service personnel after the formation of Andhra Pradesh. The Court examined whether the Central Government’s power to prescribe criteria for seniority lists was exhausted once those criteria were issued, and whether any further clarification required additional hearing. The decision addressed the balance of powers between the Centre and the State in matters of service integration following state reorganisation.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "States Reorganisation Act, 1956"
      },
      {
        "type": "Act",
        "name": "Constitution of India"
      },
      {
        "type": "Article",
        "name": "Article 226"
      },
      {
        "type": "Article",
        "name": "Article 162"
      },
      {
        "type": "Court",
        "name": "Andhra High Court"
      },
      {
        "type": "Person",
        "name": "N. Desaiah"
      },
      {
        "type": "Person",
        "name": "Kumarayya, A"
      },
      {
        "type": "Person",
        "name": "A. Ayyar"
      },
      {
        "type": "Concept",
        "name": "continuous service"
      },
      {
        "type": "Concept",
        "name": "seniority list"
      },
      {
        "type": "Concept",
        "name": "mandamus"
      },
      {
        "type": "Concept",
        "name": "integration of service personnel"
      }
    ],
    "sections": [
      {
        "title": "Petition and Relief Sought",
        "content": "The petitioners sought a writ of mandamus directing both the Central and State Governments not to prejudice their rights by counting pre‑1‑Nov‑1956 service for promotion purposes, and to restrain the State from implementing the Central decision on seniority integration."
      },
      {
        "title": "Background: Reorganisation of Andhra Pradesh",
        "content": "Section 3 of the States Reorganisation Act added districts of the former Hyderabad State to Andhra, creating Andhra Pradesh on 1‑Nov‑1956, raising the question of how health service personnel from the two predecessor states would be integrated."
      },
      {
        "title": "Statutory Framework: Sections 115 & 116",
        "content": "Section 115 mandates the Central Government to prepare criteria for inter‑state seniority lists, while Section 116 provides for the continuance of officials in their posts subject to conditions, forming the legal basis for the integration of health officers."
      },
      {
        "title": "Scope of Central Government Power",
        "content": "The Court examined whether the Central Government’s authority ends once criteria are issued, or whether it retains jurisdiction to clarify and resolve disputes arising from the implementation of those criteria."
      },
      {
        "title": "Continuous Service and Promotion Issue",
        "content": "The specific dispute concerned whether Assistant Surgeons from the former Hyderabad State could count service rendered before the reorganisation date for promotion to Assistant Director of Public Health in Andhra Pradesh."
      },
      {
        "title": "Court’s Considerations and Outcome",
        "content": "The judgment analyzed the balance between Centre‑State powers under the Reorganisation Act, the need for procedural fairness, and the statutory intent to ensure equitable treatment of all affected personnel."
      }
    ],
    "keywords": [
      "State Reorganisation Act",
      "Section 115",
      "Section 116",
      "continuous service",
      "seniority list",
      "public health department",
      "mandamus",
      "Article 226",
      "promotion",
      "Assistant Surgeon",
      "integration of service personnel",
      "Andhra Pradesh",
      "Hyderabad State",
      "jurisdiction"
    ]
  },
  {
    "id": "997cd3a0-5028-4eb6-a8f7-e4f5dcf8aa86",
    "source": "http://indiankanoon.org/doc/100003183/",
    "title": "Ors v. State of West Bengal – Quashing of charge‑sheet under West Bengal Inland Fisheries Act, 1984",
    "summary": "The petitioners, charged under Section 17A of the West Bengal Inland Fisheries Act, 1984 for allegedly filling up ponds, moved the Calcutta High Court under its inherent jurisdiction (Section 482 CrPC) to quash the charge‑sheet and the order of taking cognizance. They contended that the complaint was filed by a municipal executive officer rather than a fishery officer of the prescribed rank, that no notice was served as required by Section 17(10)(a), and that the ponds were not used for fishery, rendering the offence inapplicable. The State argued that the case diary showed actual pond filling and that the petitioners were also liable for conversion of land under the West Bengal Land Reforms Act. The Court examined the statutory requisites for taking cognizance, the procedural safeguards, and prior High Court precedents before deciding on the propriety of the charge‑sheet.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "court",
        "name": "Calcutta High Court"
      },
      {
        "type": "act",
        "name": "West Bengal Inland Fisheries Act, 1984"
      },
      {
        "type": "act",
        "name": "West Bengal Land Reforms Act"
      },
      {
        "type": "act",
        "name": "Code of Criminal Procedure"
      },
      {
        "type": "person",
        "name": "Ashim Kumar Roy (Justice)"
      },
      {
        "type": "person",
        "name": "Tapash Ghosh (Advocate for petitioners)"
      },
      {
        "type": "person",
        "name": "Swapan Kumar Mallick (Advocate for State)"
      },
      {
        "type": "person",
        "name": "Subrata Karmakar (Petitioner)"
      },
      {
        "type": "person",
        "name": "Executive Officer, Champdani Municipality"
      },
      {
        "type": "case",
        "name": "Concern For Calcutta & Ors. v. State of West Bengal & Ors. (1996)"
      },
      {
        "type": "case",
        "name": "Biswananda Naskar v. State of West Bengal & Ors. (2002)"
      }
    ],
    "sections": [
      {
        "title": "Background and Complaint",
        "content": "On 31 May 2004 the Executive Officer of Champdani Municipality lodged a complaint alleging that the petitioners illegally filled up ponds in specified plots. A FIR was registered under Section 17A of the West Bengal Inland Fisheries Act, 1984, and the investigation culminated in a charge‑sheet."
      },
      {
        "title": "Grounds for Quashing the Charge‑Sheet",
        "content": "The petitioners argued that (a) the pond‑filling allegation was false; (b) Section 22 of the Act requires a complaint by a District Fishery Officer or a Sub‑Inspector, which was not satisfied; (c) the water bodies were not used for fishery; and (d) no notice was served pursuant to Section 17(10)(a)."
      },
      {
        "title": "Inherent Jurisdiction under Section 482 CrPC",
        "content": "The High Court invoked its inherent power to prevent abuse of process, assessing whether the statutory conditions for taking cognizance had been complied with before interfering with the proceedings."
      },
      {
        "title": "Interpretation of Section 22, West Bengal Inland Fisheries Act",
        "content": "The Court examined legislative intent behind Section 22, emphasizing that only complaints by prescribed fishery officers or police of a certain rank can trigger cognizance, rendering the present complaint infirm."
      },
      {
        "title": "Procedural Deficiency – Notice under Section 17(10)(a)",
        "content": "The lack of a statutory notice to the accused before prosecution was highlighted as a fundamental breach of the procedural safeguards mandated by the Act."
      },
      {
        "title": "Conclusion",
        "content": "The petitioners’ application for quashing was evaluated in light of statutory requisites and prior judgments; the Court’s decision hinged on whether the charge‑sheet was legally tenable under the Act’s provisions."
      }
    ],
