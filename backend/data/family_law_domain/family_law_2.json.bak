      "residence order",
      "monetary relief",
      "custody order",
      "compensation",
      "magistrate",
      "aggrieved woman",
      "shared household"
    ]
  },
  {
    "id": "fcfdd361-9b21-40aa-b29a-10e35e75904c",
    "source": "https://en.wikisource.org/wiki/Hindu_Adoptions_and_Maintenance_Act,_1956",
    "title": "Hindu Adoptions and Maintenance Act, 1956 – Adoption and Maintenance Provisions",
    "summary": "The Act outlines the capacity of Hindu males and females to adopt, requiring sound mind, adulthood and, for women, unmarriage (or dissolution/death of husband). It sets conditions for a valid adoption, including the absence of a Hindu child of the same sex, a minimum age gap of 21 years between adopter and adoptee, and prohibition on adopting two children of the same sex simultaneously. The Act also presumes the authenticity of registered adoption documents. Maintenance provisions grant Hindu wives, widowed daughter‑in‑laws, children, and aged parents a right to be maintained, specifying grounds for separate maintenance and defining dependants.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "Act",
        "name": "Hindu Adoptions and Maintenance Act, 1956"
      },
      {
        "type": "Concept",
        "name": "Adoption"
      },
      {
        "type": "Concept",
        "name": "Maintenance"
      },
      {
        "type": "Person",
        "name": "Hindu wife"
      },
      {
        "type": "Person",
        "name": "Widowed daughter‑in‑law"
      },
      {
        "type": "Person",
        "name": "Minor son"
      },
      {
        "type": "Person",
        "name": "Unmarried daughter of pre‑deceased son"
      }
    ],
    "sections": [
      {
        "title": "Capacity of Male Hindu to Adopt (Sec. 7)",
        "content": "A male Hindu may adopt only if he is of sound mind and is not a minor."
      },
      {
        "title": "Capacity of Female Hindu to Adopt (Sec. 8)",
        "content": "A female Hindu may adopt only if she is of sound mind, not a minor, and either unmarried or her marriage has been dissolved, or her husband is dead."
      },
      {
        "title": "Conditions for a Valid Adoption (Sec. 11)",
        "content": "Adoption is invalid if the adopter already has a Hindu son (when adopting a son) or a Hindu daughter (when adopting a daughter); there must be at least a 21‑year age gap between adopter and adoptee if they are of opposite sexes; and two children of the same sex cannot be adopted simultaneously."
      },
      {
        "title": "Presumption Regarding Registered Adoption Documents (Sec. 16)",
        "content": "A registered document relating to an adoption is presumed to be authentic unless proved otherwise."
      },
      {
        "title": "Maintenance of Wife (Sec. 18)",
        "content": "A Hindu wife is entitled to lifetime maintenance from her husband; she may claim separate maintenance if the husband deserts her, is cruel, suffers from leprosy, has another living wife, keeps a concubine, or has ceased to be a Hindu."
      },
      {
        "title": "Maintenance of Widowed Daughter‑in‑law (Sec. 19)",
        "content": "A widowed daughter‑in‑law is entitled to maintenance from the estate of her deceased husband’s father, subject to the availability of assets."
      },
      {
        "title": "Maintenance of Children and Aged Parents (Sec. 20)",
        "content": "Children and aged parents of a Hindu are entitled to maintenance from the person who would have been liable under the Hindu Succession rules."
      },
      {
        "title": "Definition of Dependants (Sec. 21)",
        "content": "Dependants include widows, minor sons, and unmarried daughters of a pre‑deceased son."
      }
    ],
    "keywords": [
