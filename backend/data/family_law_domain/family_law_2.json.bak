      },
      {
        "type": "concept",
        "name": "Marriage Equality"
      },
      {
        "type": "concept",
        "name": "Conversion Therapy"
      },
      {
        "type": "concept",
        "name": "Self‑identified Gender"
      },
      {
        "type": "case",
        "name": "Lalita Kumari v. Government of U.P."
      }
    ],
    "sections": [
      {
        "title": "Directions to Union, State and UT Governments",
        "content": "Governments must prevent discrimination based on gender identity or sexual orientation, ensure equal access to goods and services, sensitize the public, establish hotlines and safe‑house facilities, ban conversion‑therapy and non‑consensual medical procedures, and recognize self‑identified gender as male, female or third gender without compulsory treatment."
      },
      {
        "title": "Police Guidelines",
        "content": "Police officers are prohibited from harassing queer individuals, must not force them to return to natal families, must protect them when complaints of family‑based violence arise, and must conduct a preliminary investigation under Lalita Kumari before registering FIRs in cases involving consensual queer relationships."
      },
      {
        "title": "Mental Healthcare Act Modules",
        "content": "Under Section 29(1) the appropriate government must incorporate modules on queer mental health, and Section 29(2) programmes aimed at suicide prevention must specifically address issues faced by the queer community."
      },
      {
        "title": "Conclusions on Jurisdiction and Marriage Regulation",
        "content": "The Court affirmed its authority under Article 32 to enforce fundamental rights, recognized queerness as a natural phenomenon, and clarified that marriage legislation falls within the competence of Parliament and state legislatures pursuant to Articles 245, 246 and Entry 5 of List III, leaving scope for future statutes recognising queer marriages."
      }
    ],
