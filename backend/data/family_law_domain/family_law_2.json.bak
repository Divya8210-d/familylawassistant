  {
    "id": "9c1e1ee3-ab18-4349-9da3-22c40fb06cce",
    "source": "https://en.wikipedia.org/wiki/Hindu_Succession_Act,_1956",
    "title": "Hindu Succession Act, 1956 – Intestate Inheritance Rules and Gender Equality Amendment",
    "summary": "The Hindu Succession Act, 1956 codifies intestate succession for Hindus, Buddhists, Jains and Sikhs, replacing the limited estate doctrine with absolute ownership for women. It defines Class I and Class II heirs for male decedents and sets a distinct order of inheritance for females, giving daughters equal rights only after the 2005 amendment. The Act excludes Muslims, Christians, Parsis, Jews and members of Scheduled Tribes unless notified otherwise, and disqualifies persons who commit murder or whose descendants have converted away from Hinduism. The 2005 amendment amended Sections 4, 6, 23 and 24 to grant daughters the same share as sons and to treat a Hindu woman as an absolute owner of her property.",
    "law_type": "family_law",
    "entities": [
      {
        "type": "act",
        "name": "Hindu Succession Act, 1956"
      },
      {
        "type": "amendment",
        "name": "Hindu Succession (Amendment) Act, 2005"
      },
      {
        "type": "legislature",
        "name": "Parliament of India"
      },
      {
        "type": "court_case",
        "name": "Surajmani Stella Kujur Vs. Durga Charan Hansdah"
      },
      {
        "type": "constitutional_article",
        "name": "Article 366 (Definition of Scheduled Tribes)"
      },
      {
        "type": "religion",
        "name": "Hinduism"
      },
      {
        "type": "religion",
        "name": "Buddhism"
      },
      {
        "type": "religion",
        "name": "Jainism"
      },
      {
        "type": "religion",
        "name": "Sikhism"
      },
      {
        "type": "concept",
        "name": "Limited estate"
      }
    ],
    "sections": [
      {
        "title": "Applicability – Religion",
        "content": "The Act applies to any person who is a Hindu, Buddhist, Jain or Sikh by religion, including sects such as Virashaiva, Lingayat and members of Brahmo, Prarthana or Arya Samaj, as well as to those not belonging to excluded religions if they would otherwise be governed by Hindu law."
      },
      {
        "title": "Applicability – Tribe",
        "content": "Members of Scheduled Tribes are excluded from the Act unless the Central Government issues a notification in the Official Gazette, as illustrated in Surajmani Stella Kujur v. Durga Charan Hansdah."
      },
      {
        "title": "Male Intestate Succession – Class I Heirs",
        "content": "Class I heirs include sons, daughters, widows, mother and grandchildren. Each heir receives an equal share; widows of pre‑deceased sons who have remarried are excluded."
      },
      {
        "title": "Male Intestate Succession – Class II Heirs",
        "content": "If no Class I heirs exist, the property passes to Class II heirs in a statutory order: father, son's/daughter's son, son's/daughter's daughter, brother, sister, and further descendants of siblings."
      },
      {
        "title": "Female Intestate Succession",
        "content": "Upon the death of a Hindu woman, the estate devolves first upon her sons and daughters (including children of pre‑deceased children) and her husband; thereafter to the husband's heirs, followed by the woman's parents and their heirs."
      },
      {
        "title": "Abolition of Limited Estate",
        "content": "The Act abolishes the traditional limited estate status of Hindu women, conferring absolute ownership and the full right to dispose of property, including by will."
      },
      {
        "title": "2005 Amendment – Gender Equality",
        "content": "The 2005 amendment gave daughters equal entitlement with sons to inherited property and reinforced a woman's right to hold property as an absolute owner."
      },
      {
        "title": "Exceptions and Disqualifications",
        "content": "A person who murders the decedent is barred from inheritance. A relative who converts away from Hinduism loses inheritance rights for themselves, while their descendants are disqualified unless they reconvert before the death."
      }
    ],
    "keywords": [
